# ── Cashfree Payment Gateway ──────────────────────────────────────────────────
# Get from: dashboard.cashfree.com > Payment Gateway > Developers > API Keys
# Switch to "Test mode" for sandbox keys.
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
# "sandbox" (default) uses test.cashfree.com; "production" uses api.cashfree.com
CASHFREE_MODE=sandbox

# ── Server ────────────────────────────────────────────────────────────────────
# Port the backend listens on. Defaults to 8080 if unset.
PORT=8080
